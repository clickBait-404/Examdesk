# ─── Application ───────────────────────────────────────────────
APP_NAME="ExamDesk"
APP_VERSION="1.0.0"
ENVIRONMENT="development"          # development | staging | production
DEBUG=true

# ─── Server ────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
WORKERS=1                          # increase for production

# ─── Database ──────────────────────────────────────────────────
# Neon PostgreSQL (or local)
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/examdesk"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ─── JWT Authentication ────────────────────────────────────────
SECRET_KEY="change-this-to-a-long-random-secret-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Password Reset ────────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@examdesk.edu"
SMTP_PASSWORD="your-smtp-password"
EMAILS_FROM_NAME="ExamDesk Platform"

# ─── File Storage ──────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=10

# ─── Certificate ───────────────────────────────────────────────
CERT_SECRET_KEY="cert-verification-secret"
